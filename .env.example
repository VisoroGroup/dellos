# Database
DATABASE_URL=postgresql://user:pass@host:5432/financiar

# Server
PORT=3001
NODE_ENV=development
JWT_SECRET=change-this-to-a-strong-secret

# Azure AD (Microsoft SSO)
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# Microsoft Graph (email sending)
GRAPH_SENDER_EMAIL=notifications@visoro-global.ro

# URLs
CLIENT_URL=http://localhost:5173
SERVER_URL=http://localhost:3001

# Dev only
DEV_AUTH_BYPASS=true
