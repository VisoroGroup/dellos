# Database
DATABASE_URL=postgresql://user:pass@host:5432/financiar

# Server
PORT=3001
NODE_ENV=development
# REQUIRED: must be at least 32 chars. Generate with: openssl rand -hex 32
JWT_SECRET=<generate-with-openssl-rand-hex-32>

# Azure AD (Microsoft SSO)
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# Microsoft Graph (email sending)
GRAPH_SENDER_EMAIL=notifications@visoro-global.ro

# URLs
CLIENT_URL=http://localhost:5173
SERVER_URL=http://localhost:3001

# Dev only — MUST stay false in production. Bypasses all authentication.
DEV_AUTH_BYPASS=false
